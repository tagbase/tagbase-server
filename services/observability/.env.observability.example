# Stack credentials (required by docker-compose.yml; these match local defaults)
POSTGRES_PASSWORD=tagbase
POSTGRES_PORT=5432
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=tagbase
SLACK_BOT_TOKEN=
webhook=

# Which Alloy config to mount (local LGTM is default)
ALLOY_CONFIG_FILE=config.local.alloy

# Enable app OTLP export (required when using the observability profile)
OTEL_SDK_DISABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://alloy:4317
OTEL_SERVICE_NAME=tagbase_server

# ── Grafana Cloud (required only when ALLOY_CONFIG_FILE=config.cloud.alloy) ──
# From Grafana Cloud → Connections → OpenTelemetry / Prometheus / Loki / Tempo
PROM_ENDPOINT=
PROM_USERNAME=
PROM_PASSWORD=

LOKI_ENDPOINT=
LOKI_USERNAME=
LOKI_PASSWORD=

TEMPO_ENDPOINT=
TEMPO_USERNAME=
TEMPO_PASSWORD=
